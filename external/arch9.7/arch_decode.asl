                                when ('001x', _) => __UNPREDICTABLE
                                when ('0100', '0000') => __encoding A32_uncond_as_uncondhints_barriers_SSBB_A1 // SSBB_A1
                                when ('0100', '0100') => __encoding A32_uncond_as_uncondhints_barriers_PSSBB_A1 // PSSBB_A1
                                when ('0100', !'0x00') => __encoding A32_uncond_as_uncondhints_barriers_DSB_A1 // DSB_A1
                                when ('0101', _) => __encoding A32_uncond_as_uncondhints_barriers_DMB_A1 // DMB_A1
                                when ('0110', _) => __encoding A32_uncond_as_uncondhints_barriers_ISB_A1 // ISB_A1
                                when ('0111', _) => __encoding A32_uncond_as_uncondhints_barriers_SB_A1 // SB_A1
                                when ('1xxx', _) => __UNPREDICTABLE
                        when (_, _, '011x1', _, _, _, _) => __UNALLOCATED
                        when (_, _, '0xxx0', _, _, _, _) => // preload_imm
                            __field D 24 +: 1
                            __field U 23 +: 1
                            __field R 22 +: 1
                            __field Rn 16 +: 4
                            __field imm12 0 +: 12
                            case (D, R, Rn) of
                                when ('0', '0', _) => __NOP
                                when ('0', '1', _) => __encoding A32_uncond_as_uncondhints_preload_imm_PLI_i_A1 // PLI_i_A1
                                when ('1', _, '1111') => __encoding A32_uncond_as_uncondhints_preload_imm_PLD_l_A1 // PLD_l_A1
                                when ('1', '0', !'1111') => __encoding A32_uncond_as_uncondhints_preload_imm_PLD_i_A1 // PLDW_i_A1
                                when ('1', '1', !'1111') => __encoding A32_uncond_as_uncondhints_preload_imm_PLD_i_A1 // PLD_i_A1
                        when (_, _, '1xxx0', _, _, '0', _) => // preload_reg
                            __field D 24 +: 1
                            __field U 23 +: 1
                            __field o2 22 +: 1
                            __field Rn 16 +: 4
                            __field imm5 7 +: 5
                            __field stype 5 +: 2
                            __field Rm 0 +: 4
                            case (D, o2, imm5:stype) of
                                when ('0', '0', _) => __NOP
                                when ('0', '1', '0000011') => __encoding A32_uncond_as_uncondhints_preload_reg_PLI_r_A1_RRX // PLI_r_A1_RRX
                                when ('0', '1', !'0000011') => __encoding A32_uncond_as_uncondhints_preload_reg_PLI_r_A1_RRX // PLI_r_A1
                                when ('1', '0', '0000011') => __encoding A32_uncond_as_uncondhints_preload_reg_PLD_r_A1 // PLDW_r_A1_RRX
                                when ('1', '0', !'0000011') => __encoding A32_uncond_as_uncondhints_preload_reg_PLD_r_A1 // PLDW_r_A1
                                when ('1', '1', '0000011') => __encoding A32_uncond_as_uncondhints_preload_reg_PLD_r_A1 // PLD_r_A1_RRX
                                when ('1', '1', !'0000011') => __encoding A32_uncond_as_uncondhints_preload_reg_PLD_r_A1 // PLD_r_A1
                        when (_, _, '1xxx1', _, _, '0', _) => __UNALLOCATED
                        when (_, _, '1xxxx', _, _, '1', _) => __UNPREDICTABLE
